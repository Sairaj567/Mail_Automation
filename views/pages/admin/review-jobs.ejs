<section class="section-card">
    <% if (status === 'activated') { %>
        <div class="alert alert-success">Job activated successfully.</div>
    <% } %>
    <% if (status === 'deleted') { %>
        <div class="alert alert-success">Job deleted successfully.</div>
    <% } %>
    <% if (error === 'invalid-id') { %>
        <div class="alert alert-danger">Invalid job id.</div>
    <% } %>
    <% if (error === 'not-found') { %>
        <div class="alert alert-danger">Job not found.</div>
    <% } %>
    <% if (error === 'demo') { %>
        <div class="alert alert-danger">Demo admins cannot modify jobs.</div>
    <% } %>
    <% if (error === 'server') { %>
        <div class="alert alert-danger">Something went wrong. Please try again.</div>
    <% } %>

    <div class="section-header" style="margin-bottom: 1rem;">
        <div>
            <h2>Pending Job Postings</h2>
            <p>Review, activate, or delete jobs submitted via automation.</p>
        </div>
    </div>

    <% if (jobs && jobs.length > 0) { %>
        <div class="review-table-wrap">
            <table class="summary-table review-table">
                <thead>
                    <tr>
                        <th>Job</th>
                        <th>Company</th>
                        <th>Type</th>
                        <th>Experience</th>
                        <th>Posted</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% jobs.forEach(function(job){ %>
                        <tr>
                            <td>
                                <strong><%= job.title %></strong>
                                <div class="job-meta">
                                    <span><i class="fas fa-map-marker-alt"></i> <%= job.location || 'Not specified' %></span>
                                </div>
                            </td>
                            <td><%= job.companyDisplayName || job.company || 'Unknown Company' %></td>
                            <td><span class="status-badge"><%= job.jobType || 'N/A' %></span></td>
                            <td><span class="status-badge"><%= job.experienceLevel || 'N/A' %></span></td>
                            <td><%= job.createdAt ? new Date(job.createdAt).toLocaleDateString() : '—' %></td>
                            <td>
                                <div class="review-actions">
                                    <form action="/admin/jobs/<%= job._id %>/activate" method="POST">
                                        <button type="submit" class="btn btn-success">
                                            <i class="fas fa-check"></i> Activate
                                        </button>
                                    </form>
                                    <form action="/admin/jobs/<%= job._id %>/delete" method="POST">
                                        <button type="submit" class="btn btn-danger">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="no-data" style="padding: 2.25rem 0 1rem;">
            <i class="fas fa-check-circle" style="font-size: 2.25rem; color:#16a34a;"></i>
            <h3 style="margin: 0.75rem 0 0.35rem; color:#0f172a;">No Pending Jobs</h3>
            <p style="color:#64748b;">All jobs are reviewed. Great work!</p>
        </div>
    <% } %>
</section>
