<%
  const sidebarRole = typeof role !== 'undefined' && role ? role : (typeof user !== 'undefined' && user ? user.role : 'student');
  const rawCurrentPath = typeof currentPath !== 'undefined' && currentPath ? currentPath : '';
  const normalizePath = (value) => {
    if (!value) return '';
    if (value.length > 1 && value.endsWith('/')) {
      return value.slice(0, -1);
    }
    return value;
  };
  const activePath = normalizePath(rawCurrentPath);
  const sidebarConfigs = {
    admin: {
      icon: 'fa-user-shield',
      label: 'Admin Panel',
      items: [
        { href: '/admin/dashboard', icon: 'fa-chart-line', label: 'Dashboard' },
        { href: '/admin/jobs/review', icon: 'fa-clipboard-check', label: 'Pending Jobs' },
        { href: '/admin/mail-manager', icon: 'fa-envelope-open-text', label: 'Mail Manager' },
        { href: '/admin/students', icon: 'fa-user-graduate', label: 'Students' },
        { href: '/admin/companies', icon: 'fa-building', label: 'Companies' },
        { href: '/admin/reports', icon: 'fa-chart-pie', label: 'Reports' },
      ],
    },
    company: {
      icon: 'fa-building',
      label: 'Company Hub',
      items: [
        { href: '/company/dashboard', icon: 'fa-home', label: 'Dashboard' },
        { href: '/company/jobs', icon: 'fa-briefcase', label: 'Jobs' },
        { href: '/company/applicants', icon: 'fa-users', label: 'Applicants' },
        { href: '/company/profile', icon: 'fa-id-badge', label: 'Profile' },
      ],
    },
    student: {
      icon: 'fa-graduation-cap',
      label: 'Placement Portal',
      items: [
        { href: '/student/dashboard', icon: 'fa-home', label: 'Dashboard' },
        { href: '/student/jobs', icon: 'fa-briefcase', label: 'Jobs' },
        { href: '/student/applications', icon: 'fa-file-alt', label: 'Applications' },
        { href: '/student/profile', icon: 'fa-user', label: 'Profile' },
        { href: '/student/resume', icon: 'fa-file-pdf', label: 'Resume' },
      ],
    },
  };
  const sidebarConfig = sidebarConfigs[sidebarRole] || sidebarConfigs.student;
  const isActive = (href) => {
    const normalizedHref = normalizePath(href);
    return activePath === normalizedHref || activePath.startsWith(`${normalizedHref}/`);
  };
%>

<aside class="sidebar">
  <div class="sidebar-header">
    <div class="logo">
      <i class="fas <%= sidebarConfig.icon %>"></i>
      <span><%= sidebarConfig.label %></span>
    </div>
  </div>

  <nav class="sidebar-nav">
    <% sidebarConfig.items.forEach((item) => { %>
      <a href="<%= item.href %>" class="nav-item <%= isActive(item.href) ? 'active' : '' %>">
        <i class="fas <%= item.icon %>"></i>
        <span><%= item.label %></span>
      </a>
    <% }) %>

    <a href="/auth/logout" class="nav-item logout">
      <i class="fas fa-sign-out-alt"></i>
      <span>Logout</span>
    </a>
  </nav>
</aside>
